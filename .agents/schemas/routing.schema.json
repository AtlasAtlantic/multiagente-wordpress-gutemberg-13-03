{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Routing",
  "type": "object",
  "required": ["version", "default_pipeline", "roles"],
  "properties": {
    "version": { "type": "string" },
    "default_pipeline": { "type": "string" },
    "roles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "can_route_to": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failure_route": { "type": "string" },
          "approve_route": { "type": "string" },
          "reject_route": { "type": "string" },
          "pass_state": { "type": "string" },
          "fail_route": { "type": "string" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "when", "route_to"],
        "properties": {
          "name": { "type": "string" },
          "when": { "type": "string" },
          "route_to": { "type": "string" }
        }
      }
    }
  }
}
