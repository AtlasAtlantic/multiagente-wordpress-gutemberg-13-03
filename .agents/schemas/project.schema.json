{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agents Project Context",
  "type": "object",
  "required": ["version", "project_name", "project_type", "active_profiles"],
  "properties": {
    "version": { "type": "string" },
    "project_name": { "type": "string" },
    "project_type": { "type": "string" },
    "active_profiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stack": { "type": "object" },
    "conventions": { "type": "object" },
    "paths": { "type": "object" },
    "services": { "type": "object" },
    "project_overrides": { "type": "object" },
    "tool_preferences": { "type": "object" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
