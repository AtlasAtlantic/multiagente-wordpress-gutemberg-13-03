{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agents Platform Catalog",
  "type": "object",
  "required": ["agents", "pipelines", "profiles", "domains"],
  "properties": {
    "agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pipelines": {
      "type": "array",
      "items": { "type": "string" }
    },
    "profiles": {
      "type": "object",
      "required": ["reusable", "compatibility"],
      "properties": {
        "reusable": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compatibility": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "domains": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
