{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Profile",
  "type": "object",
  "required": ["version", "profile", "description", "applicable_pipelines"],
  "properties": {
    "version": { "type": "string" },
    "profile": { "type": "string" },
    "description": { "type": "string" },
    "project_type": { "type": "string" },
    "stack": { "type": "object" },
    "paths": { "type": "object" },
    "services": { "type": "object" },
    "tool_preferences": { "type": "object" },
    "applicable_pipelines": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
